---
import '../styles/global.css';
import '../styles/designs/01-warm-local.css';
import '../styles/designs/02-bold-editorial.css';
import '../styles/designs/03-minimal-clean.css';
import '../styles/designs/04-corporate-split.css';
import '../styles/designs/05-vibrant-gradient.css';
import '../styles/designs/06-editorial-press.css';
import '../styles/designs/07-terminal-console.css';
import '../styles/designs/08-soft-bloom.css';
import '../styles/designs/09-luxe-atelier.css';
import '../styles/designs/10-pop-studio.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  meta: {
    siteName: string;
    description: string;
    image?: string;
  };
  theme: {
    ink: string;
    cream: string;
    accent: string;
    accentLight: string;
    sage: string;
  };
  design?: string;
  noindex?: boolean;
}

const { meta, theme, design = '01-warm-local', noindex = false } = Astro.props;
const canonicalUrl = Astro.url.href;
const ogImage = meta.image ?? '/og-image.jpg';

const themeStyle = `
  --ink: ${theme.ink};
  --cream: ${theme.cream};
  --accent: ${theme.accent};
  --accent-light: ${theme.accentLight};
  --sage: ${theme.sage};
`;
---

<!doctype html>
<html lang="de" style={themeStyle} data-design={design}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.siteName}</title>
    <meta name="description" content={meta.description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/dm-serif-display-normal-400-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/outfit-normal-400-latin.woff2" crossorigin />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:title"       content={meta.siteName} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:image"       content={new URL(ogImage, Astro.url).href} />
    <meta property="og:locale"      content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={meta.siteName} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image"       content={new URL(ogImage, Astro.url).href} />

  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />
    <CookieBanner />

    <script is:inline>
      // Reload immer oben starten — sonst verbirgt scroll-restoration den Countdown-Header
      // beim Reload, weil der Browser die letzte Scroll-Position wiederherstellt.
      // Ausnahme: echte Anchor-Links (#about etc.) werden vom Browser sauber positioniert.
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (!location.hash) window.scrollTo(0, 0);

      // Nav scroll effect
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('on', scrollY > 20), { passive: true });

      // Mobile nav toggle
      const burger = document.getElementById('burger');
      const navLinks = document.getElementById('navLinks');

      function setNavOpen(open) {
        burger?.classList.toggle('x', open);
        navLinks?.classList.toggle('open', open);
        burger?.setAttribute('aria-expanded', String(open));
        navLinks?.setAttribute('aria-hidden', String(!open));
      }

      burger?.addEventListener('click', () => setNavOpen(!navLinks?.classList.contains('open')));
      navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setNavOpen(false)));
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && navLinks?.classList.contains('open')) {
          setNavOpen(false);
          burger?.focus();
        }
      });

      // Scroll reveal + counter animation
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let countersTriggered = false;

      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          e.target.classList.add('in');
          if (e.target.querySelector('[data-count]') && !countersTriggered) {
            countersTriggered = true;
            document.querySelectorAll('[data-count]').forEach(el => {
              const target = +el.dataset.count;
              if (prefersReducedMotion) { el.textContent = target; return; }
              const step = target / (1400 / 16);
              let cur = 0;
              const tick = () => {
                cur = Math.min(cur + step, target);
                el.textContent = Math.round(cur);
                if (cur < target) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            });
          }
        });
      }, { threshold: 0.14 });

      document.querySelectorAll('.r').forEach(el => io.observe(el));

      // Scroll-Spy: aktiver Nav-Link spiegelt sichtbare Section
      (() => {
        const linkMap = new Map();
        document.querySelectorAll('#navLinks a[href*="#"]').forEach(a => {
          const id = a.getAttribute('href').split('#')[1];
          if (id) linkMap.set(id, a);
        });
        if (!linkMap.size) return;
        const sections = [...linkMap.keys()]
          .map(id => document.getElementById(id))
          .filter(Boolean);
        if (!sections.length) return;
        const setActive = (id) => {
          linkMap.forEach((a, k) => a.classList.toggle('active', k === id));
        };
        const spy = new IntersectionObserver((entries) => {
          // wähle den Eintrag mit höchstem Sichtbarkeitsanteil
          const visible = entries.filter(e => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]) setActive(visible[0].target.id);
        }, { threshold: [0.4, 0.6, 0.8], rootMargin: `-${getComputedStyle(document.documentElement).getPropertyValue('--nav-h') || '70px'} 0px -30% 0px` });
        sections.forEach(s => spy.observe(s));
      })();
    </script>
  </body>
</html>
