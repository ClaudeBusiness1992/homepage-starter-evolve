---
interface Member {
  name: string;
  role: string;
  bio: string;
  photo: string;
}
interface Props {
  label: string;
  headline: string;
  subline: string;
  members: Member[];
}
const { label, headline, subline, members } = Astro.props;
---

<section class="section" id="about">
  <div class="wrap">
    <div class="about-hd r">
      <span class="lbl">{label}</span>
      <h2 class="h2" set:html={headline.replace(',', ',<br />')} />
      <p class="sub" style="margin:0 auto">{subline}</p>
    </div>
    <div class="about-grid">
      {members.map((m, i) => (
        <div class={`acard r d${i + 1}`}>
          <div class="aphoto">
            {m.photo
              ? <img src={m.photo} alt={m.name} />
              : <div class="aphoto-placeholder">Foto hier einfügen<br />600 × 800 px empfohlen</div>
            }
          </div>
          <div class="abody">
            <h3 class="aname">{m.name}</h3>
            <span class="arole">{m.role}</span>
            <p class="atext">{m.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
