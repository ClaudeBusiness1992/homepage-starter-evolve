---
import SectionHeader from '../components/SectionHeader.astro';
interface Member {
  name: string;
  role: string;
  bio: string;
  photo: string;
}
interface Props {
  label: string;
  headline: string;
  subline: string;
  members: Member[];
}
const { label, headline, subline, members } = Astro.props;
---

<section class="section" id="about">
  <div class="wrap">
    <SectionHeader {label} {headline} {subline} center />
    <div class="about-grid">
      {members.map((m, i) => (
        <div class={`acard r d${i + 1}`}>
          <div class="aphoto">
            {m.photo
              ? <img src={m.photo} alt={m.name} width="600" height="800" loading="lazy" />
              : <div class="aphoto-placeholder">Foto hier einfügen<br />600 × 800 px empfohlen</div>
            }
          </div>
          <div class="abody">
            <h3 class="aname">{m.name}</h3>
            <span class="arole">{m.role}</span>
            <p class="atext">{m.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
