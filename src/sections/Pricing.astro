---
import SectionHeader from '../components/SectionHeader.astro';
interface Package {
  name: string;
  tagline: string;
  price: string;
  priceNote: string;
  featured: boolean;
  badge: string;
  features: string[];
}
interface Props {
  label: string;
  headline: string;
  subline: string;
  packages: Package[];
}
const { label, headline, subline, packages } = Astro.props;
const delays = ['d1','d2','d3'];
---

<section class="section" id="pricing">
  <div class="wrap">
    <SectionHeader {label} {headline} {subline} center />
    <div class="pricing-grid">
      {packages.map((pkg, i) => (
        <article
          class={`pcard r ${delays[i % delays.length]} ${pkg.featured ? 'feat' : ''}`}
          aria-label={pkg.name}
        >
          {pkg.badge && <div class="pbadge">{pkg.badge}</div>}
          <h3 class="pname">{pkg.name}</h3>
          <span class="ptag">{pkg.tagline}</span>
          <div class="pprice">
            <div class="amount">{pkg.price}</div>
            <div class="note">{pkg.priceNote}</div>
          </div>
          <div class="pdiv"></div>
          <ul class="plist">
            {pkg.features.map(f => <li>{f}</li>)}
          </ul>
          <a href="#contact" class={`btn btn-w ${pkg.featured ? 'btn-fill' : 'btn-outline'}`}
            aria-label={`${pkg.featured ? 'Jetzt anfragen' : 'Anfragen'} — Paket ${pkg.name}`}>
            {pkg.featured ? 'Jetzt anfragen' : 'Anfragen'}
          </a>
        </article>
      ))}
    </div>
    <p class="pricing-note r">
      Alle Pakete individuell anpassbar.
      <a href="#contact">Schreiben Sie uns</a> für ein maßgeschneidertes Angebot.
    </p>
  </div>
</section>

<script is:inline>
  (() => {
    const cards = document.querySelectorAll('#pricing .pcard');
    if (!cards.length) return;

    const select = (card) => {
      if (card.classList.contains('feat')) return;
      cards.forEach((c) => {
        c.classList.remove('feat');
        const btn = c.querySelector('.btn');
        if (btn) {
          btn.classList.replace('btn-fill', 'btn-outline');
          btn.textContent = 'Anfragen';
          btn.setAttribute('aria-label', `Anfragen — Paket ${c.getAttribute('aria-label')}`);
        }
      });
      card.classList.add('feat');
      const btn = card.querySelector('.btn');
      if (btn) {
        btn.classList.replace('btn-outline', 'btn-fill');
        btn.textContent = 'Jetzt anfragen';
        btn.setAttribute('aria-label', `Jetzt anfragen — Paket ${card.getAttribute('aria-label')}`);
      }
    };

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('a.btn')) return;
        select(card);
      });
    });
  })();
</script>
