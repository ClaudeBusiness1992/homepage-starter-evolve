---
interface ServiceItem {
  icon: string;
  title: string;
  text: string;
}
interface Props {
  label: string;
  headline: string;
  subline: string;
  items: ServiceItem[];
}
const { label, headline, subline, items } = Astro.props;
const delays = ['d1','d2','d3','d1','d2','d3'];
---

<section class="section" id="services">
  <div class="wrap">
    <div class="srv-hd r">
      <span class="lbl">{label}</span>
      <h2 class="h2">{headline}</h2>
      <p class="sub">{subline}</p>
    </div>
    <div class="srv-grid">
      {items.map((item, i) => (
        <div class={`scard r ${delays[i]}`}>
          <div class="sico">{item.icon}</div>
          <h3 class="stitle">{item.title}</h3>
          <p class="stxt">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
