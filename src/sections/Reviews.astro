---
import SectionHeader from '../components/SectionHeader.astro';
interface Review {
  name: string;
  company: string;
  rating: number;
  verified: boolean;
  date: string;
  text: string;
}
interface StatItem { value: number; label: string; }
interface Props {
  label: string;
  headline: string;
  subline: string;
  items: Review[];
  stats?: StatItem[];
  agencyName?: string;
  agencyUrl?: string;
}
const { label, headline, subline, items, stats = [], agencyName = '', agencyUrl } = Astro.props;
const delays = ['d1', 'd2', 'd3'];

const avg = items.length
  ? (items.reduce((s, r) => s + r.rating, 0) / items.length).toFixed(1)
  : '0';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': '#business',
  name: agencyName,
  ...(agencyUrl ? { url: agencyUrl } : {}),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: avg,
    reviewCount: items.length,
    bestRating: 5,
  },
  review: items.map(r => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5 },
    reviewBody: r.text,
    datePublished: r.date,
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />

<section class="section" id="reviews">
  <div class="wrap">
    <SectionHeader {label} {headline} {subline} center />
    {stats.length > 0 && (
      <div class="reviews-stats">
        {stats.map(s => (
          <div class="reviews-stat">
            <div class="reviews-stat-v">{s.value}</div>
            <div class="reviews-stat-l">{s.label}</div>
          </div>
        ))}
      </div>
    )}
    <div class="reviews-carousel">
      <button type="button" class="gallery-nav gallery-nav--prev" aria-label="Vorherige Bewertungen" data-reviews-prev>‹</button>
      <div class="reviews-grid" data-reviews-track>
        {items.map((review, i) => (
          <div class={`review-card r ${delays[i % 3]}`}>
            <div class="review-top">
              <div class="review-stars" aria-label={`${review.rating} von 5 Sternen`}>
                {Array.from({ length: review.rating }).map(() => <span aria-hidden="true">★</span>)}
              </div>
              {review.verified && (
                <span class="review-verified" title={agencyName ? `Echtheit wurde von ${agencyName} geprüft` : 'Echtheit geprüft'}>
                  ✓ Verifiziert
                </span>
              )}
            </div>
            <p class="review-text">„{review.text}"</p>
            <div class="review-footer">
              <div class="review-author">
                <div class="review-avatar">{review.name.charAt(0)}</div>
                <div>
                  <div class="review-name">{review.name}</div>
                  <div class="review-company">{review.company}</div>
                </div>
              </div>
              {review.date && <div class="review-date">{review.date}</div>}
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="gallery-nav gallery-nav--next" aria-label="Nächste Bewertungen" data-reviews-next>›</button>
    </div>
    <p class="reviews-note r">
      ✓ Alle Bewertungen stammen von verifizierten Kunden, die unsere Leistungen tatsächlich
      in Anspruch genommen haben. Die Echtheit jeder Bewertung wurde von uns geprüft und
      dokumentiert — gemäß EU-Omnibus-Richtlinie (2022/161/EU).
    </p>
  </div>
</section>

<script is:inline>
  (() => {
    const track = document.querySelector('[data-reviews-track]');
    if (!track) return;
    const prev = document.querySelector('[data-reviews-prev]');
    const next = document.querySelector('[data-reviews-next]');
    const step = () => {
      const item = track.querySelector('.review-card');
      if (!item) return track.clientWidth * 0.8;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.columnGap || style.gap || '0') || 0;
      return (item.getBoundingClientRect().width + gap) * 2;
    };
    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      const overflows = max > 1;
      const atStart = track.scrollLeft <= 1;
      const atEnd = track.scrollLeft >= max - 1;
      if (prev) prev.hidden = !overflows || atStart;
      if (next) next.hidden = !overflows || atEnd;
    };
    prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left:  step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  })();
</script>
