---
interface FooterLink {
  label: string;
  href: string;
}
interface Props {
  siteName: string;
  siteNameAccent?: string;
  copyright: string;
  links: FooterLink[];
}
const { siteName, siteNameAccent, copyright, links } = Astro.props;
const logoBefore = siteNameAccent ? siteName.replace(siteNameAccent, '') : siteName;
---

<footer>
  <div class="wrap">
    <div class="foot-row">
      <span class="foot-logo">{logoBefore}{siteNameAccent && <em>{siteNameAccent}</em>}</span>
      <nav aria-label="Footer-Navigation">
        <ul class="foot-links">
          {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
          <li><a href="#" data-cookie-settings>Cookie-Einstellungen</a></li>
        </ul>
      </nav>
      <span class="foot-copy">{copyright}</span>
    </div>
  </div>
</footer>
