---
import SectionHeader from '../components/SectionHeader.astro';
import CarouselScript from '../components/CarouselScript.astro';
interface GalleryItem {
  src: string;
  alt: string;
  caption: string;
  category: string;
}
interface Props {
  label: string;
  headline: string;
  subline: string;
  items: GalleryItem[];
}
const { label, headline, subline, items } = Astro.props;

const phClasses = ['gph-a', 'gph-b', 'gph-c', 'gph-d', 'gph-e', 'gph-f'];
---

<section class="section section--dark" id="gallery">
  <div class="wrap">
    <SectionHeader {label} {headline} {subline} center />
    <div class="gallery-carousel" data-carousel>
      <button type="button" class="gallery-nav gallery-nav--prev" aria-label="Vorherige Bilder" data-carousel-prev>‹</button>
      <div class="gallery-grid" data-carousel-track data-carousel-item=".gallery-item">
        {items.map((item, i) => (
          <div class={`gallery-item r d${(i % 3) + 1}`}>
            <div class={`gallery-img${!item.src ? ' ' + phClasses[i % phClasses.length] : ''}`}
                 {...(item.src ? {'data-lightbox': item.src, 'data-alt': item.alt, 'data-caption': item.caption, 'data-category': item.category, 'tabindex': '0', 'role': 'button', 'aria-label': item.alt ? `${item.alt} vergrößern` : 'Bild vergrößern'} : {})}>
              {item.src
                ? <img src={item.src} alt={item.alt} width="800" height="600" loading="lazy" />
                : <div class="gallery-placeholder">
                    <span class="gallery-placeholder-icon" aria-hidden="true">⬡</span>
                    <span class="gallery-placeholder-txt">Bild einfügen</span>
                  </div>
              }
              <div class="gallery-overlay"></div>
            </div>
            <div class="gallery-item-body">
              <span class="gallery-item-cat">{item.category}</span>
              <p class="gallery-item-title">{item.caption}</p>
            </div>
          </div>
        ))}
      </div>
      <button type="button" class="gallery-nav gallery-nav--next" aria-label="Nächste Bilder" data-carousel-next>›</button>
    </div>
  </div>
</section>

<CarouselScript />
