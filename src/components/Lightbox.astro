---
// Lightbox — triggered by any element with data-lightbox="<src>" data-alt="<alt>" data-caption="<text>"
---

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Bild in Vollansicht">
  <div class="lb-bg"></div>
  <div class="lb-box">
    <button class="lb-arr lb-prev" type="button" aria-label="Vorheriges Bild" hidden>‹</button>
    <img class="lb-img" src="" alt="" />
    <button class="lb-arr lb-next" type="button" aria-label="Nächstes Bild" hidden>›</button>
    <div class="lb-caption"></div>
  </div>
</div>

<style is:global>

/* ── LIGHTBOX OVERLAY ── */
#lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity .25s ease, visibility .25s ease;
}
#lightbox.is-open { opacity: 1; visibility: visible; }

.lb-bg {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.88);
  backdrop-filter: blur(6px);
  cursor: pointer;
}

/* ── BOX — wraps tightly around image width ── */
.lb-box {
  position: relative;
  z-index: 1;
  display: inline-flex;
  flex-direction: column;
  overflow: visible;      /* buttons dürfen außerhalb liegen */
  transform: scale(.88);
  transition: transform .28s cubic-bezier(.34,1.56,.64,1);
}
#lightbox.is-open .lb-box { transform: scale(1); }

/* ── BILD — 80 % Bildschirm, Platz für Caption abgezogen ── */
.lb-img {
  max-width: 80vw;
  max-height: calc(80vh - 3.5rem);
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  display: block;
  box-shadow: 0 32px 90px rgba(0,0,0,.75);
  flex-shrink: 0;
  cursor: pointer;
}

/* ── PFEILE — 0.5 rem Abstand zur linken / rechten Bildkante ── */
.lb-arr {
  position: absolute;
  /* Bildmitte = Mitte lb-box minus halbe Caption-Höhe (≈1.75rem) */
  top: calc(50% - 1.75rem);
  transform: translateY(-50%);
  z-index: 2;
  width: 2.5rem;
  height: 2.5rem;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 50%;
  color: rgba(255,255,255,.45);
  font-size: 1.4rem;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .18s, border-color .18s, color .18s, transform .18s;
}
.lb-arr:hover {
  background: rgba(255,255,255,.22);
  border-color: rgba(255,255,255,.45);
  color: #fff;
  backdrop-filter: blur(4px);
  transform: translateY(-50%) scale(1.08);
}
.lb-arr:focus-visible { outline: 2px solid rgba(255,255,255,.7); outline-offset: 2px; }
/* right-edge of prev = .5rem left of lb-box left edge */
.lb-prev { right: calc(100% + .5rem); }
/* left-edge of next = .5rem right of lb-box right edge */
.lb-next { left:  calc(100% + .5rem); }
.lb-arr[hidden] { display: none; }

/* ── CAPTION — weiß wie About-Karte ── */
.lb-caption {
  min-height: 2.8rem;
  padding: .6rem 1.1rem;
  background: #ffffff;
  border-radius: 0 0 var(--r-lg) var(--r-lg);
  color: var(--ink, #1a1a2e);
  font-size: .82rem;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── HOVER-TRIGGER ── */
@keyframes lb-shake {
  0%,100% { transform: rotate(0deg) scale(1); }
  20%     { transform: rotate(-1.2deg) scale(1.015); }
  40%     { transform: rotate(1.2deg)  scale(1.015); }
  60%     { transform: rotate(-.7deg)  scale(1.008); }
  80%     { transform: rotate(.7deg)   scale(1.008); }
}

.gallery-img[data-lightbox] { cursor: zoom-in; }
.gallery-img[data-lightbox] img { transition: filter .3s ease; }
.gallery-img[data-lightbox]:hover img {
  filter: grayscale(35%) brightness(.85);
  animation: lb-shake .55s ease-out forwards;
}

.aphoto[data-lightbox] { cursor: zoom-in; }
.aphoto[data-lightbox] img { transition: filter .3s ease; }
.aphoto[data-lightbox]:hover img {
  filter: grayscale(35%) brightness(.85);
  animation: lb-shake .55s ease-out forwards;
}

/* "Click me" badge */
.gallery-img[data-lightbox]::after,
.aphoto[data-lightbox]::after {
  content: 'Click me ↗';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) scale(.75);
  background: rgba(255,255,255,.95);
  color: #1a1a2e;
  padding: .35rem 1rem;
  border-radius: 100px;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .07em;
  text-transform: uppercase;
  white-space: nowrap;
  opacity: 0;
  transition: opacity .25s, transform .25s;
  pointer-events: none;
  z-index: 6;
}
.gallery-img[data-lightbox]:hover::after,
.aphoto[data-lightbox]:hover::after {
  opacity: 1;
  transform: translate(-50%,-50%) scale(1);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .gallery-img[data-lightbox]:hover img,
  .aphoto[data-lightbox]:hover img { animation: none; }
  .lb-box { transition: none; }
}

/* Mobile: Pfeile ins Bild wenn kein Platz daneben */
@media (max-width: 700px) {
  .lb-prev { right: auto; left: .5rem; top: 50%; }
  .lb-next { left: auto; right: .5rem; top: 50%; }
}

</style>

<script is:inline>
(function () {
  const lb        = document.getElementById('lightbox');
  if (!lb) return;
  const img       = lb.querySelector('.lb-img');
  const bg        = lb.querySelector('.lb-bg');
  const btnPrev   = lb.querySelector('.lb-prev');
  const btnNext   = lb.querySelector('.lb-next');
  const captionEl = lb.querySelector('.lb-caption');

  let srcs = [];
  let idx  = 0;

  const showSlide = (i) => {
    img.src = srcs[i].src;
    img.alt = srcs[i].alt || '';
    if (captionEl) {
      const parts = [srcs[i].category, srcs[i].caption].filter(Boolean);
      captionEl.textContent = parts.length ? parts.join(' — ') : ' ';
    }
    if (btnPrev) btnPrev.hidden = srcs.length <= 1 || i === 0;
    if (btnNext) btnNext.hidden = srcs.length <= 1 || i === srcs.length - 1;
  };

  const open = (src, alt, group) => {
    srcs = (group && group.length) ? group : [{ src, alt }];
    idx  = srcs.findIndex(s => s.src === src);
    if (idx < 0) idx = 0;
    showSlide(idx);
    lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    lb.classList.remove('is-open');
    document.body.style.overflow = '';
    lb.addEventListener('transitionend', () => { img.src = ''; }, { once: true });
  };

  const goPrev = () => { if (idx > 0)               { idx--; showSlide(idx); } };
  const goNext = () => { if (idx < srcs.length - 1) { idx++; showSlide(idx); } };

  document.addEventListener('click', (e) => {
    const t = e.target.closest('[data-lightbox]');
    if (!t) return;
    const src = t.dataset.lightbox || t.querySelector('img')?.src || '';
    const alt = t.dataset.alt      || t.querySelector('img')?.alt || '';
    if (!src) return;
    const section = t.closest('section');
    const group = section
      ? [...section.querySelectorAll('[data-lightbox]')]
          .filter(el => el.dataset.lightbox)
          .map(el => ({
            src:      el.dataset.lightbox,
            alt:      el.dataset.alt      || el.querySelector('img')?.alt || '',
            caption:  el.dataset.caption  || '',
            category: el.dataset.category || '',
          }))
      : null;
    open(src, alt, group);
  });

  lb.addEventListener('click', (e) => {
    if (!e.target.closest('.lb-arr')) close();
  });
  btnPrev?.addEventListener('click', (e) => { e.stopPropagation(); goPrev(); });
  btnNext?.addEventListener('click', (e) => { e.stopPropagation(); goNext(); });

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  { e.preventDefault(); goPrev(); }
    if (e.key === 'ArrowRight') { e.preventDefault(); goNext(); }
  });

  let touchStartX = 0;
  lb.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  lb.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) { dx < 0 ? goNext() : goPrev(); }
  }, { passive: true });
}());
</script>
