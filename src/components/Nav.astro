---
interface NavLink {
  label: string;
  href: string;
  cta?: boolean;
}
interface Props {
  siteName: string;
  siteNameAccent?: string;
  links?: NavLink[];
}
const { siteName, siteNameAccent, links = [] } = Astro.props;
const accentIdx = siteNameAccent ? siteName.indexOf(siteNameAccent) : -1;
const logoBefore = accentIdx > -1 ? siteName.slice(0, accentIdx) : siteName;
const logoAfter  = accentIdx > -1 ? siteName.slice(accentIdx + (siteNameAccent?.length ?? 0)) : '';
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const resolveHref = (href: string) => (isHome || !href.startsWith('#')) ? href : `/${href}`;
---

<nav id="nav" aria-label="Hauptnavigation">
  <div class="wrap">
    <div class="nav-row">
      <a href="/" class="logo">{logoBefore}{siteNameAccent && <em>{siteNameAccent}</em>}{logoAfter}</a>
      {links.length > 0 && (
        <ul class="nav-ul" id="navLinks">
          {links.map(l => (
            <li>
              <a href={resolveHref(l.href)} class={l.cta ? 'cta-link' : ''}>{l.label}</a>
            </li>
          ))}
        </ul>
      )}
      <button class="burger" id="burger" aria-label="Menü" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>
