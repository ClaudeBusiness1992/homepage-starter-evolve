---
interface NavLink {
  label: string;
  href: string;
  cta?: boolean;
}
interface Props {
  siteName: string;
  siteNameAccent?: string;
  links?: NavLink[];
}
const { siteName, siteNameAccent, links = [] } = Astro.props;
const logoBefore = siteNameAccent ? siteName.replace(siteNameAccent, '') : siteName;
---

<nav id="nav" aria-label="Hauptnavigation">
  <div class="wrap">
    <div class="nav-row">
      <a href="/" class="logo">{logoBefore}{siteNameAccent && <em>{siteNameAccent}</em>}</a>
      {links.length > 0 && (
        <ul class="nav-ul" id="navLinks">
          {links.map(l => (
            <li>
              <a href={l.href} class={l.cta ? 'cta-link' : ''}>{l.label}</a>
            </li>
          ))}
        </ul>
      )}
      <button class="burger" id="burger" aria-label="Menü" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>
