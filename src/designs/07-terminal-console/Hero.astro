---
interface Props {
  label: string;
  headline: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { label, headline, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section id="hero" class="tc-hero">
  <div class="tc-grid-bg" aria-hidden="true"></div>
  <div class="wrap">
    <div class="tc-window r">
      <div class="tc-titlebar">
        <div class="tc-dots">
          <span class="tc-dot tc-dot-r"></span>
          <span class="tc-dot tc-dot-y"></span>
          <span class="tc-dot tc-dot-g"></span>
        </div>
        <div class="tc-tab">~/welcome.sh</div>
        <div class="tc-status"><span class="tc-led"></span>online</div>
      </div>

      <div class="tc-body">
        <pre class="tc-pre" aria-hidden="true">
<span class="tc-prompt">$</span> <span class="tc-cmd">whoami</span>
<span class="tc-out">{'>'} {label.toLowerCase()}</span>

<span class="tc-prompt">$</span> <span class="tc-cmd">cat headline.txt</span>
        </pre>

        <h1 class="tc-h1">{headline}<span class="tc-cursor" aria-hidden="true">_</span></h1>

        <pre class="tc-pre" aria-hidden="true">
<span class="tc-prompt">$</span> <span class="tc-cmd">describe --short</span>
        </pre>

        <p class="tc-sub">{subline}</p>

        <pre class="tc-pre" aria-hidden="true">
<span class="tc-prompt">$</span> <span class="tc-cmd">deploy --action</span>
        </pre>

        <div class="tc-actions">
          <a href="#contact" class="tc-btn tc-btn-primary">[ {ctaPrimary} ]</a>
          <a href="#services" class="tc-btn tc-btn-ghost">[ {ctaSecondary} ]</a>
        </div>
      </div>

      <div class="tc-statusbar">
        <span><span class="tc-led tc-led-ok"></span>main</span>
        <span class="tc-sep">│</span>
        <span>UTF-8</span>
        <span class="tc-sep">│</span>
        <span>build: stable</span>
        <span class="tc-spacer"></span>
        <span class="tc-time" id="tcTime">--:--:--</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const el = document.getElementById('tcTime');
    if (!el) return;
    const tick = () => {
      const d = new Date();
      el.textContent = d.toTimeString().slice(0, 8);
    };
    tick();
    setInterval(tick, 1000);
  })();
</script>

<style>
  .tc-hero {
    background: var(--tc-bg);
    color: var(--tc-text);
    min-height: 100vh;
    padding: calc(var(--nav-h) + 3rem) 0 4rem;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    font-family: var(--mono);
  }

  .tc-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    pointer-events: none;
  }

  .tc-window {
    background: var(--tc-bg-2);
    border: 1px solid var(--tc-border);
    border-radius: 10px;
    box-shadow: 0 24px 80px rgba(0,0,0,.6), inset 0 0 0 1px rgba(255,255,255,.02);
    overflow: hidden;
    max-width: 920px;
    margin: 0 auto;
    position: relative;
  }

  .tc-titlebar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: .75rem 1rem;
    background: var(--tc-bg-3);
    border-bottom: 1px solid var(--tc-border);
    font-size: .84rem;
    color: var(--tc-text-dim);
  }
  .tc-dots { display: flex; gap: .4rem; }
  .tc-dot { width: 12px; height: 12px; border-radius: 50%; }
  /* Mac-Window-Dots — semantische Farben, bleiben fix */
  .tc-dot-r { background: #ff5f57; }
  .tc-dot-y { background: #ffbd2e; }
  .tc-dot-g { background: #28c840; }
  .tc-tab {
    background: var(--tc-bg-2);
    padding: .25rem .9rem;
    border-radius: 6px 6px 0 0;
    color: var(--tc-text);
    border: 1px solid var(--tc-border);
    border-bottom: none;
    margin-bottom: -.75rem;
    margin-top: -.4rem;
  }
  .tc-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: .4rem;
    color: var(--tc-accent-2);
  }
  .tc-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--tc-accent-2);
    box-shadow: 0 0 8px var(--tc-accent-2);
    animation: tc-pulse 2s infinite;
  }
  /* OK-LED Variante — semantisches Blau, bleibt fix */
  .tc-led-ok { background: #58a6ff; box-shadow: 0 0 6px #58a6ff; }
  @keyframes tc-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }

  .tc-body { padding: 2rem 2.25rem 2.5rem; }

  .tc-pre {
    font-family: inherit;
    color: var(--tc-text-dim);
    font-size: .92rem;
    line-height: 1.4;
    margin: 0;
    white-space: pre-wrap;
  }
  .tc-prompt { color: var(--accent); font-weight: 700; }
  .tc-cmd { color: var(--tc-text); }
  .tc-out { color: var(--tc-accent-3); display: block; }

  .tc-h1 {
    font-family: var(--sans);
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    line-height: 1.15;
    color: var(--tc-text);
    margin: .8rem 0 1.5rem;
    letter-spacing: -.02em;
    font-weight: 700;
  }
  .tc-cursor {
    display: inline-block;
    color: var(--accent);
    margin-left: .1em;
    animation: tc-blink 1.1s steps(2) infinite;
  }
  @keyframes tc-blink { 50% { opacity: 0; } }

  .tc-sub {
    font-family: var(--sans);
    color: var(--tc-text);
    font-size: 1rem;
    line-height: 1.7;
    margin: .8rem 0 1.5rem;
    max-width: 640px;
  }

  .tc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin-top: .8rem;
  }
  .tc-btn {
    font-family: inherit;
    font-size: .9rem;
    padding: .85rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all .15s;
    letter-spacing: .02em;
    font-weight: 500;
  }
  .tc-btn-primary {
    background: var(--accent);
    color: var(--tc-bg);
    font-weight: 700;
    box-shadow: 0 0 0 1px var(--accent), 0 0 24px rgba(232,99,27,.3);
  }
  .tc-btn-primary:hover {
    background: var(--accent-light);
    box-shadow: 0 0 0 1px var(--accent-light), 0 0 32px rgba(232,99,27,.5);
  }
  .tc-btn-ghost {
    background: transparent;
    color: var(--tc-text);
    border: 1px solid var(--tc-border-soft);
  }
  .tc-btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

  .tc-statusbar {
    display: flex;
    align-items: center;
    gap: .85rem;
    padding: .55rem 1.25rem;
    background: var(--tc-bg);
    border-top: 1px solid var(--tc-border);
    font-size: .78rem;
    color: var(--tc-text-dim);
  }
  .tc-statusbar .tc-led { width: 6px; height: 6px; }
  .tc-sep { color: var(--tc-border-soft); }
  .tc-spacer { flex: 1; }
  .tc-time { color: var(--accent); font-variant-numeric: tabular-nums; }

  @media (max-width: 640px) {
    .tc-body { padding: 1.5rem 1.25rem 2rem; }
    .tc-statusbar { font-size: .7rem; padding: .55rem 1rem; gap: .5rem; }
    .tc-actions { flex-direction: column; }
    .tc-btn { text-align: center; }
  }
</style>
