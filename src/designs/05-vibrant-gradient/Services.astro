---
import SectionHeader from '../../components/SectionHeader.astro';
interface ServiceItem { icon: string; title: string; text: string; }
interface Props { label: string; headline: string; subline: string; items: ServiceItem[]; }
const { label, headline, subline, items } = Astro.props;
---

<section class="section" id="services">
  <div class="wrap">
    <SectionHeader {label} {headline} {subline} center />
    <div class="sv5-grid">
      {items.map((item, i) => (
        <div class={`sv5-card r d${(i % 3) + 1}`}>
          <div class="sv5-top">
            <span class="sv5-icon">{item.icon}</span>
          </div>
          <div class="sv5-body">
            <h3 class="sv5-title">{item.title}</h3>
            <p class="sv5-text">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #services { background: var(--vg-light-bg); color: var(--vg-light-text); }
  .sv5-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .sv5-card {
    background: var(--vg-light-bg);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(26,26,46,.06);
    border: 1px solid var(--vg-light-line);
    transition: transform .25s, box-shadow .25s;
    display: flex;
    flex-direction: column;
  }
  .sv5-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 40px rgba(26,26,46,.13);
  }
  .sv5-top {
    background: linear-gradient(135deg, var(--vg-accent) 0%, var(--vg-accent-2) 100%);
    padding: 2rem 2rem 1.5rem;
  }
  .sv5-icon { font-size: 2.2rem; display: block; }
  .sv5-body { padding: 1.5rem 2rem 2rem; flex: 1; }
  .sv5-title { font-size: 1.1rem; font-weight: 600; color: var(--vg-light-text); margin-bottom: .5rem; }
  .sv5-text { color: var(--vg-light-text-soft); font-size: .9rem; line-height: 1.7; margin: 0; }
  @media (max-width: 900px) { .sv5-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .sv5-grid { grid-template-columns: 1fr; } }
</style>
