---
interface Props {
  label: string;
  headline: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { label, headline, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section id="hero" class="sb-hero">
  <svg class="sb-blob sb-blob-1" viewBox="0 0 400 400" aria-hidden="true">
    <path fill="currentColor" d="M325,70Q360,150,340,230Q320,310,235,335Q150,360,90,295Q30,230,55,140Q80,50,165,40Q250,30,325,70Z"/>
  </svg>
  <svg class="sb-blob sb-blob-2" viewBox="0 0 400 400" aria-hidden="true">
    <path fill="currentColor" d="M315,90Q345,180,310,255Q275,330,190,330Q105,330,80,250Q55,170,90,95Q125,20,210,30Q295,40,315,90Z"/>
  </svg>
  <svg class="sb-leaf" viewBox="0 0 60 60" aria-hidden="true">
    <path fill="currentColor" d="M5,55 Q5,5 55,5 Q40,30 5,55 Z"/>
  </svg>

  <div class="wrap">
    <div class="sb-inner r">
      <p class="sb-greet">— Hallo, schön dass du da bist.</p>

      <span class="sb-pill">
        <span class="sb-pill-dot" aria-hidden="true"></span>
        {label}
      </span>

      <h1 class="sb-h1">{headline}</h1>

      <p class="sb-sub">{subline}</p>

      <div class="sb-btns">
        <a href="#contact" class="sb-btn sb-btn-primary">
          {ctaPrimary}
          <span class="sb-arrow" aria-hidden="true">→</span>
        </a>
        <a href="#services" class="sb-btn sb-btn-ghost">{ctaSecondary}</a>
      </div>

      <div class="sb-card r">
        <div class="sb-card-row">
          <div class="sb-card-circle">★</div>
          <div>
            <strong>5,0 / 5</strong>
            <span>Kundenbewertung</span>
          </div>
        </div>
        <div class="sb-card-divide" aria-hidden="true"></div>
        <div class="sb-card-row">
          <div class="sb-card-circle sb-card-circle-2">✓</div>
          <div>
            <strong>2–3 Wochen</strong>
            <span>bis online</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <svg class="sb-wave" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
    <path fill="var(--sb-bg-2)" d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"/>
  </svg>
</section>

<style>
  .sb-hero {
    background: linear-gradient(180deg, var(--sb-bg) 0%, var(--sb-bg-2) 100%);
    color: var(--sb-text);
    min-height: 100vh;
    padding: calc(var(--nav-h) + 3rem) 0 8rem;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .sb-wave path { fill: var(--sb-bg-2); }

  .sb-blob {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }
  .sb-blob-1 {
    color: var(--sb-accent);
    opacity: .08;
    width: 520px;
    height: 520px;
    top: -100px;
    right: -120px;
    animation: sb-drift 18s ease-in-out infinite alternate;
  }
  .sb-blob-2 {
    color: var(--sb-sage);
    opacity: .12;
    width: 400px;
    height: 400px;
    bottom: -80px;
    left: -100px;
    animation: sb-drift 24s ease-in-out infinite alternate-reverse;
  }
  .sb-leaf {
    position: absolute;
    width: 90px;
    height: 90px;
    color: var(--sb-accent);
    opacity: .08;
    top: 30%;
    left: 6%;
    transform: rotate(-15deg);
    pointer-events: none;
    animation: sb-sway 6s ease-in-out infinite;
  }
  @keyframes sb-drift {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(20px, -30px) rotate(8deg); }
  }
  @keyframes sb-sway {
    0%, 100% { transform: rotate(-15deg) translateY(0); }
    50% { transform: rotate(-8deg) translateY(-12px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sb-blob, .sb-leaf { animation: none; }
  }

  .sb-inner {
    position: relative;
    z-index: 2;
    max-width: 660px;
    margin: 0 auto;
    text-align: center;
  }

  .sb-greet {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.5rem, 2.5vw, 2.1rem);
    color: var(--sb-accent);
    margin-bottom: 1.5rem;
    line-height: 1.2;
    position: relative;
    display: inline-block;
  }
  .sb-greet::after {
    content: '';
    display: block;
    width: 60%;
    height: 2px;
    margin-top: .35rem;
    background: linear-gradient(90deg, var(--sb-accent), transparent);
    border-radius: 2px;
    opacity: .55;
  }

  .sb-pill {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: rgba(255,255,255,.7);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--sb-accent) 15%, transparent);
    border-radius: 100px;
    padding: .5rem 1.1rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--sb-text);
    margin-bottom: 1.75rem;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--sb-accent) 8%, transparent);
  }
  .sb-pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sb-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--sb-accent) 18%, transparent);
  }

  .sb-h1 {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
    line-height: 1.1;
    letter-spacing: -.015em;
    color: var(--sb-text);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .sb-sub {
    font-size: 1.1rem;
    color: var(--sb-text-soft);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto 2.5rem;
  }

  .sb-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }
  .sb-btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: 1rem 1.75rem;
    border-radius: 100px;
    font-size: .95rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform .25s cubic-bezier(.4,.7,.2,1.3), box-shadow .25s;
  }
  .sb-btn-primary {
    background: var(--sb-accent);
    color: var(--sb-on-accent);
    box-shadow: 0 8px 0 -2px color-mix(in srgb, var(--sb-accent) 30%, transparent), 0 12px 24px color-mix(in srgb, var(--sb-accent) 25%, transparent);
  }
  .sb-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 11px 0 -2px color-mix(in srgb, var(--sb-accent) 30%, transparent), 0 16px 32px color-mix(in srgb, var(--sb-accent) 35%, transparent);
  }
  .sb-btn-primary:hover .sb-arrow {
    transform: translateX(3px);
  }
  .sb-arrow {
    transition: transform .25s;
  }
  .sb-btn-ghost {
    background: rgba(255,255,255,.65);
    color: var(--sb-text);
    border: 1.5px solid rgba(26,26,46,.12);
    box-shadow: 0 6px 16px rgba(26,26,46,.05);
  }
  .sb-btn-ghost:hover {
    transform: translateY(-2px);
    border-color: var(--sb-accent);
    color: var(--sb-accent);
  }

  .sb-card {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--sb-bg-3);
    border-radius: 28px;
    padding: 1.1rem 1.75rem;
    box-shadow: 0 16px 40px color-mix(in srgb, var(--sb-accent) 10%, transparent), 0 4px 12px rgba(26,26,46,.04);
    text-align: left;
  }
  .sb-card-row {
    display: flex;
    align-items: center;
    gap: .75rem;
  }
  .sb-card-row strong {
    display: block;
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--sb-text);
    line-height: 1.1;
  }
  .sb-card-row span {
    font-size: .78rem;
    color: var(--sb-text-soft);
  }
  .sb-card-circle {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--sb-accent), var(--sb-accent-2));
    color: var(--sb-on-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
  }
  .sb-card-circle-2 {
    background: linear-gradient(135deg, var(--sb-sage), color-mix(in srgb, var(--sb-sage) 70%, white));
  }
  .sb-card-divide {
    width: 1px;
    height: 32px;
    background: rgba(26,26,46,.1);
  }

  .sb-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    width: 100%;
    height: 80px;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .sb-card { flex-direction: column; align-items: stretch; gap: .9rem; padding: 1rem 1.25rem; }
    .sb-card-divide { width: 100%; height: 1px; }
    .sb-leaf { display: none; }
  }
</style>
