---
interface Props {
  label: string;
  headline: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { label, headline, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section id="hero">
  <div class="wrap">
    <div class="hero-inner r">
      <span class="hero-label">{label}</span>
      <h1 class="hero-h1">{headline}</h1>
      <p class="hero-sub">{subline}</p>
      <div class="hero-btns">
        <a href="#contact" class="hero-cta-primary">{ctaPrimary} <span aria-hidden="true">→</span></a>
        <a href="#services" class="hero-cta-secondary">{ctaSecondary}</a>
      </div>
    </div>
  </div>
  <div class="hero-rule"></div>
</section>

<style>
#hero {
  min-height: 100vh;
  background: var(--mc-bg);
  color: var(--mc-text);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: var(--nav-h);
  position: relative;
}

.hero-inner {
  max-width: 760px;
  padding: 6rem 0 7rem;
}

.hero-label {
  display: inline-block;
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--mc-text-soft);
  border-bottom: 1px solid var(--mc-line);
  padding-bottom: .4rem;
  margin-bottom: 2rem;
}

.hero-h1 {
  font-family: var(--serif);
  font-size: clamp(2.8rem, 5.5vw, 5.5rem);
  line-height: 1.1;
  letter-spacing: -.01em;
  color: var(--mc-text);
  margin-bottom: 1.5rem;
  font-weight: 400;
}

.hero-sub {
  font-size: 1.05rem;
  color: var(--mc-text-soft);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 2.5rem;
}

.hero-btns {
  display: flex;
  align-items: center;
  gap: 2rem;
}

.hero-cta-primary {
  font-size: .95rem;
  font-weight: 600;
  color: var(--mc-text);
  text-decoration: none;
  border-bottom: 1.5px solid var(--mc-text);
  padding-bottom: 2px;
  transition: color .2s, border-color .2s;
}
.hero-cta-primary:hover { color: var(--mc-accent); border-color: var(--mc-accent); }

.hero-cta-secondary {
  font-size: .95rem;
  color: var(--mc-text-soft);
  text-decoration: none;
  transition: color .2s;
}
.hero-cta-secondary:hover { color: var(--mc-text); }

.hero-rule {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: var(--mc-line);
}
</style>
