---
import SectionHeader from '../../components/SectionHeader.astro';
interface Member { name: string; role: string; bio: string; photo: string; }
interface Props { label: string; headline: string; subline: string; members: Member[]; }
const { label, headline, subline, members } = Astro.props;
---

<section class="section" id="about">
  <div class="wrap">
    <SectionHeader {label} headline={headline.replace(',', ',<br />')} {subline} />
    <div class="ab2-list">
      {members.map((m, i) => (
        <div class={`ab2-row r d${(i % 3) + 1}`}>
          <span class="ab2-num">{String(i + 1).padStart(2, '0')}</span>
          <div class="ab2-photo">
            {m.photo
              ? <img src={m.photo} alt={m.name} width="80" height="80" loading="lazy" />
              : <div class="ab2-initials">{m.name.split(' ').map((w: string) => w[0]).join('')}</div>
            }
          </div>
          <div class="ab2-meta">
            <h3 class="ab2-name">{m.name}</h3>
            <span class="ab2-role">{m.role}</span>
          </div>
          <p class="ab2-bio">{m.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #about { background: var(--bld-cream); }
  .ab2-list { border-bottom: 1px solid var(--bld-line-cream); }
  .ab2-row {
    display: grid;
    grid-template-columns: 2.5rem 80px 1fr 2fr;
    gap: 2.5rem;
    align-items: center;
    padding: 2.5rem 0;
    border-top: 1px solid var(--bld-line-cream);
  }
  .ab2-num { font-family: var(--serif); font-size: 1rem; color: var(--bld-accent); }
  .ab2-photo img {
    width: 80px; height: 80px; border-radius: 50%; object-fit: cover; display: block;
  }
  .ab2-initials {
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--bld-on-cream); color: var(--bld-cream);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; font-weight: 600; letter-spacing: .02em;
  }
  .ab2-name { font-size: 1.3rem; margin-bottom: .2rem; color: var(--bld-on-cream); }
  .ab2-role { font-size: .875rem; color: var(--bld-accent); font-weight: 500; }
  .ab2-bio { margin: 0; color: var(--bld-on-cream-soft); font-size: .9rem; line-height: 1.7; }
  @media (max-width: 900px) {
    .ab2-row { grid-template-columns: 80px 1fr; grid-template-rows: auto auto; gap: 1rem 1.5rem; }
    .ab2-num { display: none; }
    .ab2-bio { grid-column: 1 / -1; }
  }
</style>
