---
interface Props {
  label: string;
  headline: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { label, headline, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section id="hero">
  <div class="hero-split">
    <div class="hero-left">
      <div class="hero-content r">
        <span class="hero-label">{label}</span>
        <h1 class="hero-h1">{headline}</h1>
        <p class="hero-sub">{subline}</p>
        <div class="hero-btns">
          <a href="#contact" class="btn btn-fill">{ctaPrimary} <span aria-hidden="true">→</span></a>
          <a href="#services" class="btn btn-outline">{ctaSecondary}</a>
        </div>
      </div>
    </div>
    <div class="hero-right" aria-hidden="true">
      <div class="hero-deco">
        <div class="deco-lines">
          {Array.from({length: 6}).map(() => <div class="deco-line"></div>)}
        </div>
        <div class="deco-card" style="top: 5%; left: 14%; transform: rotate(-3deg);">
          <span class="deco-icon">✓</span>
          <p>Website in 2–3 Wochen</p>
        </div>
        <div class="deco-card deco-review" style="top: 12%; right: 5%; transform: rotate(2deg);">
          <span class="deco-stars" aria-hidden="true">★★★★★</span>
          <strong>Sandra Weber</strong>
          <em>„Innerhalb von 2 Wochen online."</em>
        </div>
        <div class="deco-card deco-card-sm" style="top: 28%; left: 4%; transform: rotate(2deg);">
          <span class="deco-icon">◇</span>
          <p>Mobile-First</p>
        </div>
        <div class="deco-card deco-card-sm" style="top: 32%; right: 28%; transform: rotate(-3deg);">
          <span class="deco-icon">🛡</span>
          <p>DSGVO-konform</p>
        </div>
        <div class="deco-card deco-review" style="top: 40%; left: 24%; transform: rotate(-2deg);">
          <span class="deco-stars" aria-hidden="true">★★★★★</span>
          <strong>Dr. T. Müller</strong>
          <em>„Top bei meinen Patienten."</em>
        </div>
        <div class="deco-card deco-card-sm" style="top: 45%; right: 28%; transform: rotate(-2deg);">
          <span class="deco-icon">€</span>
          <p>Faire Preise</p>
        </div>
        <div class="deco-card" style="top: 53%; left: 6%; transform: rotate(3deg);">
          <span class="deco-icon">⚙</span>
          <p>SEO inklusive</p>
        </div>
        <div class="deco-card deco-card-sm" style="top: 64%; right: 8%; transform: rotate(2deg);">
          <span class="deco-icon">✎</span>
          <p>Texte inklusive</p>
        </div>
        <div class="deco-card" style="top: 71%; left: 22%; transform: rotate(-3deg);">
          <span class="deco-icon">⚡</span>
          <p>Schnelle Ladezeit</p>
        </div>
        <div class="deco-card deco-card-sm" style="top: 84%; left: 8%; transform: rotate(1deg);">
          <span class="deco-icon">⟳</span>
          <p>Pflege-Service</p>
        </div>
        <div class="deco-card deco-card-sm" style="top: 88%; right: 16%; transform: rotate(-2deg);">
          <span class="deco-icon">✦</span>
          <p>Persönlich</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
#hero {
  min-height: 100vh;
  padding-top: var(--nav-h);
  overflow: hidden;
}

.hero-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - var(--nav-h));
  width: 100%;
}

.hero-left, .hero-right {
  min-width: 0;
}

.hero-left {
  background: var(--cream);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 5rem clamp(1.5rem, 5vw, 4rem);
}

.hero-content {
  max-width: 540px;
  width: 100%;
}

.hero-label {
  display: block;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1.5rem;
}

.hero-h1 {
  font-family: var(--serif);
  font-size: clamp(2.6rem, 4.5vw, 4.2rem);
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 1.25rem;
  letter-spacing: -.01em;
}

.hero-sub {
  font-size: 1rem;
  color: var(--ink-muted);
  line-height: 1.75;
  margin-bottom: 2.5rem;
  max-width: 440px;
}

.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

.hero-right {
  background: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hero-deco { position: relative; width: 100%; height: 100%; }

.deco-lines {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
}
.deco-line {
  border-right: 1px solid rgba(255,255,255,.05);
}

.deco-card {
  position: absolute;
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--r);
  padding: .65rem 1rem;
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  color: rgba(255,255,255,.92);
  font-size: .82rem;
  font-weight: 500;
  white-space: nowrap;
  box-shadow: 0 8px 24px rgba(0,0,0,.25);
  transition: transform .3s, box-shadow .3s;
}
.deco-card:hover {
  transform: translateY(-2px) rotate(0deg) !important;
  box-shadow: 0 12px 32px rgba(0,0,0,.4);
}

.deco-card-sm {
  font-size: .75rem;
  padding: .5rem .85rem;
  gap: .4rem;
}

.deco-icon {
  font-size: 1rem;
  color: var(--accent);
  flex-shrink: 0;
}

.deco-review {
  flex-direction: column;
  align-items: flex-start;
  gap: .15rem;
  padding: .7rem .95rem;
  max-width: 220px;
  white-space: normal;
}
.deco-review .deco-stars {
  color: #f5b300;
  font-size: .82rem;
  letter-spacing: .04em;
  line-height: 1;
}
.deco-review strong {
  font-size: .82rem;
  color: rgba(255,255,255,.95);
  font-weight: 600;
  margin-top: .1rem;
}
.deco-review em {
  font-size: .72rem;
  font-style: italic;
  color: rgba(255,255,255,.6);
  line-height: 1.35;
}

@media (max-width: 768px) {
  .hero-split { grid-template-columns: 1fr; }
  .hero-left { padding: 4rem 2rem; }
  .hero-content { margin: 0 auto; }
  .hero-right { display: none; }
}
</style>
