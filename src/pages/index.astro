---
import metaConfig    from '../../config/meta.json';
import designConfig  from '../../config/design.json';
import contentConfig from '../../config/content.json';
import extrasConfig  from '../../config/extras.json';
import Base     from '../layouts/Base.astro';
import Nav      from '../components/Nav.astro';
import Hero01   from '../sections/Hero.astro';
import Hero02   from '../designs/02-bold-editorial/Hero.astro';
import Hero03   from '../designs/03-minimal-clean/Hero.astro';
import Hero04   from '../designs/04-corporate-split/Hero.astro';
import Hero05   from '../designs/05-vibrant-gradient/Hero.astro';
import Hero06   from '../designs/06-editorial-press/Hero.astro';
import Hero07   from '../designs/07-terminal-console/Hero.astro';
import Hero08   from '../designs/08-soft-bloom/Hero.astro';
import Hero09   from '../designs/09-luxe-atelier/Hero.astro';
import Hero10   from '../designs/10-pop-studio/Hero.astro';
import About01  from '../sections/About.astro';
import About02  from '../designs/02-bold-editorial/About.astro';
import About04  from '../designs/04-corporate-split/About.astro';
import Services01 from '../sections/Services.astro';
import Services02 from '../designs/02-bold-editorial/Services.astro';
import Services05 from '../designs/05-vibrant-gradient/Services.astro';
import Countdown from '../sections/Countdown.astro';
import Pricing  from '../sections/Pricing.astro';
import Gallery  from '../sections/Gallery.astro';
import Reviews  from '../sections/Reviews.astro';
import Booking  from '../sections/Booking.astro';
import Contact  from '../sections/Contact.astro';
import Footer   from '../sections/Footer.astro';

const { design = '01-warm-local' } = designConfig;
const { meta, theme } = metaConfig;
const { sections: s } = contentConfig;
const { extras: x = {} } = extrasConfig;

// Hero: every design has its own Hero
const HeroComponents = {
  '01-warm-local':       Hero01,
  '02-bold-editorial':   Hero02,
  '03-minimal-clean':    Hero03,
  '04-corporate-split':  Hero04,
  '05-vibrant-gradient': Hero05,
  '06-editorial-press':  Hero06,
  '07-terminal-console': Hero07,
  '08-soft-bloom':       Hero08,
  '09-luxe-atelier':     Hero09,
  '10-pop-studio':       Hero10,
};

// About / Services: only overrides; everyone else falls back to default (About01/Services01)
const AboutOverrides = {
  '02-bold-editorial':  About02,
  '04-corporate-split': About04,
};
const ServicesOverrides = {
  '02-bold-editorial':   Services02,
  '05-vibrant-gradient': Services05,
};

const Hero     = HeroComponents[design]    ?? Hero01;
const About    = AboutOverrides[design]    ?? About01;
const Services = ServicesOverrides[design] ?? Services01;

// Build nav in actual scroll order (Sections-Reihenfolge unten in <main>):
// about → services → gallery → pricing → reviews → booking → contact (cta)
const labelFor = (id: string, fallback: string) =>
  (meta.nav ?? []).find((l: any) => l.section === id)?.label ?? fallback;

const cta = (meta.nav ?? []).find((l: any) => l.cta);
const orderedSections = [
  { id: 'about',    label: labelFor('about',    'Über uns'),    enabled: s.about?.enabled !== false },
  { id: 'services', label: labelFor('services', 'Leistungen'),  enabled: s.services?.enabled !== false },
  { id: 'gallery',  label: 'Galerie',                            enabled: !!(x.active?.gallery && x.gallery) },
  { id: 'pricing',  label: labelFor('pricing',  'Preise'),      enabled: s.pricing?.enabled !== false },
  { id: 'reviews',  label: 'Bewertungen',                        enabled: !!(x.active?.reviews && x.reviews) },
  { id: 'booking',  label: 'Buchung',                            enabled: !!(x.active?.booking && x.booking) },
];

const navLinks = [
  ...orderedSections.filter(o => o.enabled).map(o => ({ label: o.label, href: `#${o.id}`, section: o.id })),
  ...(cta ? [cta] : [{ label: 'Kontakt', href: '#contact', section: 'contact', cta: true }]),
];
---

<Base meta={meta} theme={theme} design={design}>
  <Nav siteName={meta.siteName} siteNameAccent={meta.siteNameAccent} links={navLinks} />

  <main id="main" tabindex="-1">
    {(s.hero.enabled || (x.active?.countdown && x.countdown)) && (
      <div class="hero-snap">
        {x.active?.countdown && x.countdown && <Countdown {...x.countdown} />}
        {s.hero.enabled && <Hero {...s.hero} mockupUrl={Astro.site ? Astro.site.host : undefined} />}
      </div>
    )}
    {s.about.enabled     && <About     {...s.about} />}
    {s.services.enabled  && <Services  {...s.services} />}
    {x.active?.gallery   && x.gallery  && <Gallery   {...x.gallery} />}
    {s.pricing?.enabled  && <Pricing   {...s.pricing} />}
    {x.active?.reviews   && x.reviews  && <Reviews  {...x.reviews} stats={s.stats?.enabled ? s.stats.items : []} agencyName={meta.siteName} agencyUrl={Astro.site?.href} telephone={meta.phone} />}
    {x.active?.booking   && x.booking  && <Booking  {...x.booking} />}
    {(s.contact?.enabled || s.footer?.enabled) && (
      <div class="contact-footer-snap">
        {s.contact?.enabled  && <Contact   {...s.contact} email={meta.email} phone={meta.phone} phoneDisplay={meta.phoneDisplay} availability={x.booking?.availability} />}
        {s.footer?.enabled   && <Footer    siteName={meta.siteName} siteNameAccent={meta.siteNameAccent} copyright={meta.copyright} links={s.footer.links} />}
      </div>
    )}
  </main>
</Base>

<script is:inline>
(function () {
  const getTargets = () => [
    ...document.querySelectorAll('#main > section, #main > .hero-snap, #main > .contact-footer-snap')
  ];

  let locked = false;
  let lockTimer = null;
  const html = document.documentElement;

  const unlock = () => {
    locked = false;
    clearTimeout(lockTimer);
  };

  const go = (dir) => {
    if (locked) return;
    const list = getTargets();
    if (!list.length) return;

    const navH = parseFloat(
      getComputedStyle(html).getPropertyValue('--nav-h') || '72'
    );
    const sy = window.scrollY;

    // Current = highest snap target whose snap-position (offsetTop - navH) ≤ scrollY + tolerance
    let idx = 0;
    for (let i = 0; i < list.length; i++) {
      if (list[i].offsetTop - navH <= sy + 5) idx = i;
    }

    const next = list[idx + (dir > 0 ? 1 : -1)];
    if (!next) return;

    locked = true;

    // Disable CSS scroll-snap during programmatic scroll — prevents the snap engine
    // from re-snapping to a different section after our scrollTo lands.
    html.style.scrollSnapType = 'none';

    const top = Math.max(0, next.offsetTop - navH);
    window.scrollTo({ top, behavior: 'smooth' });

    const done = () => {
      html.style.scrollSnapType = '';
      clearTimeout(lockTimer);
      lockTimer = setTimeout(unlock, 700);    // 700 ms: Momentum-Events abklingen lassen
    };

    // scrollend fires when the smooth-scroll animation fully completes.
    // Fallback: 1.2 s covers even slow smooth-scroll on heavy pages.
    if ('onscrollend' in window) {
      window.addEventListener('scrollend', done, { once: true });
      lockTimer = setTimeout(() => {
        window.removeEventListener('scrollend', done);
        done();
      }, 1200);
    } else {
      lockTimer = setTimeout(done, 900);
    }
  };

  // Ist el innerhalb eines horizontal scrollbaren Containers?
  const inHScroll = (el) => {
    while (el && el !== document.body) {
      const s = window.getComputedStyle(el);
      if ((s.overflowX === 'auto' || s.overflowX === 'scroll')
          && el.scrollWidth > el.clientWidth + 2) return true;
      el = el.parentElement;
    }
    return false;
  };

  // Wheel-Delta-Akkumulator: Momentum-Events nach einem Snap summieren sich
  // erst ab 60 px auf — so springt kein zweites Snap durch Trägheit aus.
  let wheelAcc = 0;
  let wheelTimer = null;

  window.addEventListener('wheel', (e) => {
    if (Math.abs(e.deltaX) > Math.abs(e.deltaY) * 0.5) return; // diagonal / horizontal
    if (inHScroll(e.target)) return;                             // innerhalb Karussell
    e.preventDefault();
    if (locked) {
      // Navigation läuft — Akkumulator nullen, damit Momentum nicht auflädt
      wheelAcc = 0;
      clearTimeout(wheelTimer);
      return;
    }
    wheelAcc += e.deltaY;
    clearTimeout(wheelTimer);
    wheelTimer = setTimeout(() => { wheelAcc = 0; }, 200);
    if (Math.abs(wheelAcc) < 60) return;   // Mindest-Delta für einen echten Scroll
    const dir = wheelAcc;
    wheelAcc = 0;
    clearTimeout(wheelTimer);
    go(dir);
  }, { passive: false });

  // Arrow / Page keys — skip when a form field has focus
  document.addEventListener('keydown', (e) => {
    const down = e.key === 'ArrowDown' || e.key === 'PageDown';
    const up   = e.key === 'ArrowUp'   || e.key === 'PageUp';
    if (!down && !up) return;
    const tag = (document.activeElement?.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
    e.preventDefault();
    go(down ? 1 : -1);
  });
}());
</script>
