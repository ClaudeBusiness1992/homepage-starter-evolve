---
import metaConfig    from '../../config/meta.json';
import designConfig  from '../../config/design.json';
import contentConfig from '../../config/content.json';
import extrasConfig  from '../../config/extras.json';
import Base      from '../layouts/Base.astro';
import Nav       from '../components/Nav.astro';
import Hero01    from '../sections/Hero.astro';
import About01   from '../sections/About.astro';
import Services01 from '../sections/Services.astro';
import Countdown from '../sections/Countdown.astro';
import Pricing  from '../sections/Pricing.astro';
import Gallery  from '../sections/Gallery.astro';
import Reviews  from '../sections/Reviews.astro';
import Booking   from '../sections/Booking.astro';
import Sponsors  from '../sections/Sponsors.astro';
import Contact   from '../sections/Contact.astro';
import Footer    from '../sections/Footer.astro';
import SidebarAds from '../components/SidebarAds.astro';

const { design = '01-warm-local' } = designConfig;
const { meta, theme } = metaConfig;
const { sections: s } = contentConfig;
const { extras: x = {} } = extrasConfig;

const Hero     = Hero01;
const About    = About01;
const Services = Services01;

// Build nav in actual scroll order (Sections-Reihenfolge unten in <main>):
// about → services → gallery → pricing → reviews → booking → contact (cta)
const labelFor = (id: string, fallback: string) =>
  (meta.nav ?? []).find((l: any) => l.section === id)?.label ?? fallback;

const cta = (meta.nav ?? []).find((l: any) => l.cta);
const orderedSections = [
  { id: 'about',    label: labelFor('about',    'Über uns'),    enabled: s.about?.enabled !== false },
  { id: 'services', label: labelFor('services', 'Leistungen'),  enabled: s.services?.enabled !== false },
  { id: 'gallery',  label: 'Galerie',                            enabled: !!(x.active?.gallery && x.gallery) },
  { id: 'pricing',  label: labelFor('pricing',  'Preise'),      enabled: s.pricing?.enabled !== false },
  { id: 'reviews',  label: 'Bewertungen',                        enabled: !!(x.active?.reviews  && x.reviews) },
  { id: 'booking',  label: 'Buchung',                            enabled: !!(x.active?.booking  && x.booking) },
  { id: 'sponsors', label: 'Sponsoren',                          enabled: !!(x.active?.sponsors && x.sponsors) },
];

const navLinks = [
  ...orderedSections.filter(o => o.enabled).map(o => ({ label: o.label, href: `#${o.id}`, section: o.id })),
  ...(cta ? [cta] : [{ label: 'Kontakt', href: '#contact', section: 'contact', cta: true }]),
];
---

<Base meta={meta} theme={theme} design={design}>
  <Nav siteName={meta.siteName} siteNameAccent={meta.siteNameAccent} links={navLinks} />

  <main id="main" tabindex="-1">
    {(s.hero.enabled || (x.active?.countdown && x.countdown)) && (
      <div class="hero-snap">
        {x.active?.countdown && x.countdown && <Countdown {...x.countdown} />}
        {s.hero.enabled && <Hero {...s.hero} mockupUrl={Astro.site ? Astro.site.host : undefined} />}
      </div>
    )}
    {s.about.enabled     && <About     {...s.about} />}
    {s.services.enabled  && <Services  {...s.services} />}
    {x.active?.gallery   && x.gallery  && <Gallery   {...x.gallery} />}
    {s.pricing?.enabled  && <Pricing   {...s.pricing} />}
    {x.active?.reviews   && x.reviews  && <Reviews  {...x.reviews} stats={s.stats?.enabled ? s.stats.items : []} agencyName={meta.siteName} agencyUrl={Astro.site?.href} telephone={meta.phone} />}
    {x.active?.booking   && x.booking   && <Booking   {...x.booking} />}
    {x.active?.sponsors  && x.sponsors  && <Sponsors  {...x.sponsors} />}
    {(s.contact?.enabled || s.footer?.enabled) && (
      <div class="contact-footer-snap">
        {s.contact?.enabled  && <Contact   {...s.contact} email={meta.email} phone={meta.phone} phoneDisplay={meta.phoneDisplay} availability={x.booking?.availability} />}
        {s.footer?.enabled   && <Footer    siteName={meta.siteName} siteNameAccent={meta.siteNameAccent} copyright={meta.copyright} links={s.footer.links} />}
      </div>
    )}
  </main>

  {x.active?.sidebarAds && x.sidebarAds && (
    <SidebarAds left={x.sidebarAds.left} right={x.sidebarAds.right} />
  )}
</Base>

<script is:inline>
(function () {
  const getTargets = () => [
    ...document.querySelectorAll('#main > section, #main > .hero-snap, #main > .contact-footer-snap')
  ];

  let locked      = false;
  let animDone    = false;
  let doneAt      = 0;
  let scrollTimer = null;
  let unlockTimer = null;
  const html = document.documentElement;

  // CSS mandatory snap kämpft mit dem JS-Smooth-Scroll: nach scrollTo() landet der
  // Browser manchmal 1–2 px neben dem Snap-Punkt und springt dann zum nächsten weiter
  // ("2-Seiten-Spring"). Fix: CSS snap dauerhaft deaktivieren, JS übernimmt komplett.
  html.style.scrollSnapType = 'none';

  const unlock = () => { locked = false; animDone = false; doneAt = 0; unlockTimer = null; };

  const scheduleUnlock = () => {
    if (unlockTimer) return;               // never reset — let the current timer expire
    unlockTimer = setTimeout(unlock, 220); // shorter cooldown for snappier response
  };

  // Called once the page scroll animation is truly finished.
  const done = () => {
    animDone = true;
    doneAt   = Date.now();
    scheduleUnlock();
  };

  const go = (dir) => {
    if (locked) return;
    const list = getTargets();
    if (!list.length) return;

    const navH = parseFloat(
      getComputedStyle(html).getPropertyValue('--nav-h') || '72'
    );
    const sy = window.scrollY;

    let idx = 0;
    for (let i = 0; i < list.length; i++) {
      if (list[i].offsetTop - navH <= sy + 5) idx = i;
    }

    const next = list[idx + (dir > 0 ? 1 : -1)];
    if (!next) return;

    locked   = true;
    animDone = false;

    const top = Math.max(0, next.offsetTop - navH);
    window.scrollTo({ top, behavior: 'smooth' });

    if ('onscrollend' in window) {
      // Filter to document-level scroll only — carousel/gallery scrollend events
      // bubble to window too and would prematurely trigger done().
      const onEnd = (e) => {
        // Viewport scrollend targets document or documentElement; element scrolls target the element itself.
        if (e.target !== document && e.target !== document.documentElement) return;
        window.removeEventListener('scrollend', onEnd);
        clearTimeout(scrollTimer);
        done();
      };
      window.addEventListener('scrollend', onEnd);
      scrollTimer = setTimeout(() => {
        window.removeEventListener('scrollend', onEnd);
        done();
      }, 1200);
    } else {
      scrollTimer = setTimeout(done, 900);
    }
  };

  // True if el (or an ancestor) is a scroll container with actual overflow — H or V.
  // Lets carousels, inner panels, and overflowing textareas scroll naturally.
  const inScrollContainer = (el) => {
    while (el && el !== document.body) {
      const s = window.getComputedStyle(el);
      if ((s.overflowX === 'auto' || s.overflowX === 'scroll') && el.scrollWidth  > el.clientWidth  + 2) return true;
      if ((s.overflowY === 'auto' || s.overflowY === 'scroll') && el.scrollHeight > el.clientHeight + 2) return true;
      el = el.parentElement;
    }
    return false;
  };

  let wheelAcc = 0;
  let wheelTimer = null;

  window.addEventListener('wheel', (e) => {
    if (window.innerWidth < 768) return;
    if (Math.abs(e.deltaX) > Math.abs(e.deltaY) * 0.5) return;
    if (inScrollContainer(e.target)) return;
    e.preventDefault();
    if (locked) {
      wheelAcc = 0;
      clearTimeout(wheelTimer);
      if (animDone && Date.now() - doneAt > 1800) unlock(); // safety valve only
      return;
    }
    wheelAcc += e.deltaY;
    clearTimeout(wheelTimer);
    wheelTimer = setTimeout(() => { wheelAcc = 0; }, 200);
    if (Math.abs(wheelAcc) < 66) return;
    const dir = wheelAcc;
    wheelAcc = 0;
    clearTimeout(wheelTimer);
    go(dir);
  }, { passive: false });

  // Prevent <select> from changing its value on wheel in Chrome (native behaviour
  // can bypass the window-level e.preventDefault above on some platforms).
  document.querySelectorAll('select').forEach(sel => {
    sel.addEventListener('wheel', (e) => {
      if (window.innerWidth >= 768) e.preventDefault();
    }, { passive: false });
  });

  document.addEventListener('keydown', (e) => {
    if (window.innerWidth < 768) return;
    const down = e.key === 'ArrowDown' || e.key === 'PageDown';
    const up   = e.key === 'ArrowUp'   || e.key === 'PageUp';
    if (!down && !up) return;
    const tag = (document.activeElement?.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
    e.preventDefault();
    go(down ? 1 : -1);
  });

  // ── SETTLE ────────────────────────────────────────────────────────────────
  // Snaps the page to the nearest section after any scroll that bypassed go()
  // (scrollbar drag, nav-link anchor jump, window resize, etc.).
  let settleTimer = null;
  const settle = () => {
    if (window.innerWidth < 768) return;
    if (locked) return;
    const list = getTargets();
    if (!list.length) return;
    const navH = parseFloat(getComputedStyle(html).getPropertyValue('--nav-h') || '72');
    const sy   = window.scrollY;
    let closest = list[0], minDist = Infinity;
    for (const el of list) {
      const dist = Math.abs(el.offsetTop - navH - sy);
      if (dist < minDist) { minDist = dist; closest = el; }
    }
    if (minDist <= 4) return; // already on a snap point
    locked = true; animDone = false;
    window.scrollTo({ top: Math.max(0, closest.offsetTop - navH), behavior: 'smooth' });
    const onSettle = (e) => {
      if (e.target !== document && e.target !== document.documentElement) return;
      window.removeEventListener('scrollend', onSettle);
      clearTimeout(settleTimer);
      unlock();
    };
    if ('onscrollend' in window) {
      window.addEventListener('scrollend', onSettle);
      settleTimer = setTimeout(() => { window.removeEventListener('scrollend', onSettle); unlock(); }, 900);
    } else {
      settleTimer = setTimeout(unlock, 900);
    }
  };

  if ('onscrollend' in window) {
    // Fires once after any page scroll ends — including those not from go().
    window.addEventListener('scrollend', (e) => {
      if (e.target !== document && e.target !== document.documentElement) return;
      if (locked) return;
      settle();
    });
  } else {
    // Fallback: debounce on scroll idle for browsers without scrollend.
    let idleTimer = null;
    window.addEventListener('scroll', () => {
      if (window.innerWidth < 768) return;
      clearTimeout(idleTimer);
      idleTimer = setTimeout(settle, 150);
    }, { passive: true });
  }

  // Re-snap after resize — section offsets shift when the viewport changes.
  let resizeTimer = null;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(settle, 300);
  });
}());
</script>
